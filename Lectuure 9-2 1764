import sys
input=sys.stdin.readline
a,b=map(int,input().rstrip().split())
ls=[]
ls_2=[]
for i in range(a):
    name=input().rstrip()
    ls.append(name)
for i in range(b):
    name_2=input().rstrip()
    ls_2.append(name_2)
ls_3=list(set(ls)&set(ls_2))
ls_3.sort()
print(len(ls_3))
for ch in range(len(ls_3)):
    print(ls_3[ch])
