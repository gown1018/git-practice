word=input()
total=0
ls=list()
for ch in word:
    if ch.islower():
        k=ord(ch)-96
    else:
        k=ord(ch)-38
    total+=k
for i in range(1,total+1):
    p=total%i
    if p==0:
        ls.append(p)
    else:
        p=p
if len(ls)==2 or len(ls)==1:
    print("It is a prime word.")
else:
    print("It is not a prime word.")